# --- Polymarket CLOB Momentum Bot config ---
# Copy to .env and fill in. NEVER commit your .env file.

# Safety: start in dry-run mode. Only set to "false" after you have tested
# thoroughly and understand the risks.
DRY_RUN=true

# ---------- Wallet / signing ----------
# Private key of the EOA that funds/signs orders. Hex, 0x-prefixed.
# NEVER share this key. Use a dedicated trading wallet with limited funds.
PRIVATE_KEY=

# Signature type used when authenticating to the CLOB.
#   0 = EOA             (signer == funder, your own wallet)
#   1 = POLY_PROXY      (Polymarket proxy wallet; funder != signer)
#   2 = GNOSIS_SAFE     (Safe smart contract wallet)
SIGNATURE_TYPE=0

# Funder address. For EOA this is usually the wallet address derived from
# PRIVATE_KEY. For POLY_PROXY / GNOSIS_SAFE this MUST be the proxy/safe address
# that actually holds USDC on Polygon.
FUNDER_ADDRESS=

# Polygon mainnet chain id (do not change unless you know what you're doing).
CHAIN_ID=137

# CLOB host.
CLOB_HOST=https://clob.polymarket.com

# ---------- Strategy parameters ----------
# Lookback window for the moving average, in price-history points.
MA_WINDOW=20

# Interval for price history. One of: 1h, 6h, 1d, 1w, 1m, max.
# "max" returns the full history and is the safest default for MA20 on
# short-lived markets; shorten (1d, 1w) once you know the market is old enough.
PRICE_INTERVAL=max

# Fidelity (resolution) in minutes for price history. 60 = 1-hour candles.
PRICE_FIDELITY=60

# ---------- Risk limits ----------
# Max USDC notional per single trade.
MAX_TRADE_SIZE_USDC=5

# Max USDC notional spent across all trades in a UTC day.
MAX_DAILY_SPEND_USDC=25

# Max number of simultaneous open positions.
MAX_OPEN_POSITIONS=3

# Minimum 24h volume (USDC) a market must have to be eligible.
MIN_VOLUME_USDC=5000

# Minimum on-book liquidity (USDC) required.
MIN_LIQUIDITY_USDC=500

# Max allowed bid/ask spread as a fraction of mid (0.05 = 5%).
MAX_SPREAD=0.05

# Cooldown (seconds) between trades on the same market.
TRADE_COOLDOWN_SEC=300

# Master kill switch: if true, the bot will refuse to place any orders.
KILL_SWITCH=false

# Optional comma-separated allowlist of category/tag slugs (empty = allow all).
CATEGORY_ALLOWLIST=

# Optional comma-separated allowlist of market condition IDs (empty = allow all).
MARKET_ALLOWLIST=

# ---------- Runtime ----------
# Seconds between strategy loop iterations.
POLL_INTERVAL_SEC=60

# How many top markets (by 24h volume) to consider each loop.
MAX_MARKETS=20

# Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
